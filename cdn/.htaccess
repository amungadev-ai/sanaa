# CDN .htaccess for cdn.sanaathrumylens.co.ke

# Enable rewrite engine
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================
# SECURITY HEADERS
# ============================================

<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"

    # Prevent clickjacking
    Header set X-Frame-Options "ALLOW-FROM https://sanaathrumylens.co.ke"

    # XSS protection
    Header set X-XSS-Protection "1; mode=block"

    # Referrer policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ============================================
# CACHING — Aggressive for CDN
# ============================================

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/avif "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 7 days"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    <FilesMatch "\.(svg)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>

# ============================================
# PROTECT SENSITIVE FILES
# ============================================

# Block access to config.php (Apache 2.2 + 2.4 compatible)
<Files "config.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>

# Block access to .htaccess
<Files ".htaccess">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>

# Block access to hidden files
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ============================================
# DIRECTORY LISTING
# ============================================

Options -Indexes

# ============================================
# API ROUTES (clean URLs)
# ============================================

RewriteRule ^api/upload$ api/upload.php [L,QSA]
RewriteRule ^api/delete$ api/delete.php [L,QSA]
RewriteRule ^api/list$ api/list.php [L,QSA]

# ============================================
# CORS for image serving (public read access)
# ============================================

<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|svg)$">
        Header set Access-Control-Allow-Origin "https://sanaathrumylens.co.ke"
        Header set Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
    </FilesMatch>
</IfModule>
